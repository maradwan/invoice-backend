# Application secrets
OPENAI_API_KEY=replace-with-your-openai-key

# MongoDB credentials
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=replace-with-strong-password
MONGO_URI=mongodb://admin:replace-with-strong-password@mongodb:27017

# App config
DB_NAME=image_db
COLLECTION_IMAGES=images
COLLECTION_USERS=users

# Monitoring credentials
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-strong-password

# Langfuse profile credentials (optional profile)
LANGFUSE_NEXTAUTH_URL=http://localhost:3003
LANGFUSE_POSTGRES_PASSWORD=replace-with-strong-password
LANGFUSE_CLICKHOUSE_PASSWORD=replace-with-strong-password
LANGFUSE_NEXTAUTH_SECRET=replace-with-long-random-secret
LANGFUSE_SALT=replace-with-long-random-salt
LANGFUSE_MINIO_ACCESS_KEY=langfuse-minio
LANGFUSE_MINIO_SECRET_KEY=replace-with-strong-password
