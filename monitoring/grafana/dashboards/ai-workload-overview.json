{
  "id": null,
  "uid": "invoice-ai-workload",
  "title": "Invoice Backend - AI Workload",
  "tags": ["invoice", "ai", "langchain", "prometheus"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Tokens Used (Total, 1h)",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(ai_tokens_total{token_type=\"total\"}[1h]))",
          "legendFormat": "tokens"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "AI Requests (Total, selected range)",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(ai_requests_total[$__range]))",
          "legendFormat": "requests"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "AI Error Rate (1h, %)",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum(increase(ai_requests_total{status=\"error\"}[1h])) / clamp_min(sum(increase(ai_requests_total[1h])), 1)",
          "legendFormat": "error %"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "p95 AI Latency (s)",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(ai_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Token Usage by Type (1h window)",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(ai_tokens_total[1h])) by (token_type)",
          "legendFormat": "{{token_type}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "AI Requests by Status (cumulative)",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(ai_requests_total) by (status)",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "AI Errors by Type (1h window)",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(ai_errors_total[1h])) by (error_type)",
          "legendFormat": "{{error_type}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "AI Request Latency by Status (p50/p95)",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum(rate(ai_request_duration_seconds_bucket[5m])) by (le, status))",
          "legendFormat": "p50 {{status}}"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum(rate(ai_request_duration_seconds_bucket[5m])) by (le, status))",
          "legendFormat": "p95 {{status}}"
        }
      ]
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Estimated AI Cost (USD, 1h)",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(ai_cost_usd_total[1h]))",
          "legendFormat": "usd"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Avg Tokens / Successful Request (1h)",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(ai_tokens_total{token_type=\"total\"}[1h])) / clamp_min(sum(increase(ai_requests_total{status=\"success\"}[1h])), 1)",
          "legendFormat": "tokens/request"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "AI Parse Failures by Reason (1h)",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(ai_parse_failures_total[1h])) by (reason)",
          "legendFormat": "{{reason}}"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Invoice Pipeline Stage p95 Latency (s)",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 30 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(invoice_processing_duration_seconds_bucket[5m])) by (le, stage))",
          "legendFormat": "{{stage}}"
        }
      ]
    },
    {
      "id": 99,
      "type": "text",
      "title": "Data Source Legend",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 36 },
      "options": {
        "mode": "markdown",
        "content": "**This dashboard uses Prometheus AI workload metrics (emitted by backend).**\\n\\n- **Prometheus panels**: requests/tokens/errors/cost/stage latency\\n- **Langfuse traces/scores/users/sessions**: available in Langfuse UI\\n- **Tempo traces**: backend OTEL spans in Tempo dashboard/Explore"
      }
    }
  ],
  "templating": { "list": [] },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  }
}
