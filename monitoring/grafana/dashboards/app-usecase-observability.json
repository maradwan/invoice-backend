{
  "id": null,
  "uid": "invoice-app-usecases",
  "title": "Invoice Backend - App Use Cases",
  "tags": ["invoice", "opentelemetry", "prometheus", "usecase"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "HTTP Requests (selected range)",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(app_route_requests_total[$__range]))",
          "legendFormat": "requests"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "HTTP Error Rate (5xx, selected range)",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum(increase(app_route_requests_total{status_class=\"5xx\"}[$__range])) / clamp_min(sum(increase(app_route_requests_total[$__range])), 1)",
          "legendFormat": "error %"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Invoice Extractions (selected range)",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(invoice_processing_total{stage=\"invoice_extraction\",status=\"success\"}[$__range]))",
          "legendFormat": "success"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "p95 Upload+Extraction Latency (s)",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(invoice_processing_duration_seconds_bucket{stage=\"invoice_extraction\"}[5m])) by (le))",
          "legendFormat": "p95"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Requests by Route (selected range)",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(app_route_requests_total[$__range])) by (route)",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Route p95 Latency (s)",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(app_route_request_duration_seconds_bucket[5m])) by (le, route))",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Invoice Extraction by File Type",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(invoice_processing_total{stage=\"invoice_extraction\"}[$__range])) by (file_type, status)",
          "legendFormat": "{{file_type}} {{status}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Supplier Match Item Outcomes",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(supplier_match_items_total[$__range])) by (match)",
          "legendFormat": "{{match}}"
        }
      ]
    },
    {
      "id": 99,
      "type": "text",
      "title": "Data Source Legend",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 24 },
      "options": {
        "mode": "markdown",
        "content": "**This dashboard uses Prometheus app/use-case metrics (with OTEL instrumentation in backend).**\\n\\n- **Prometheus panels**: route/use-case KPIs and latency\\n- **Tempo traces**: distributed traces in Tempo dashboard/Explore\\n- **Loki logs**: app logs in Loki dashboards\\n- **Langfuse traces/scores/users**: available in Langfuse UI"
      }
    }
  ],
  "templating": { "list": [] },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  }
}
