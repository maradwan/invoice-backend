{
  "id": null,
  "uid": "invoice-mongodb-overview",
  "title": "Invoice Backend - MongoDB Overview",
  "tags": ["invoice", "mongodb", "prometheus"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "MongoDB Up",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "refId": "A",
          "expr": "max(mongodb_up)",
          "legendFormat": "up"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Connections (current)",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "refId": "A",
          "expr": "max(mongodb_ss_connections{conn_type=\"current\"}) or max(mongodb_ss_connections_current)",
          "legendFormat": "current"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Connections (available)",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "refId": "A",
          "expr": "max(mongodb_ss_connections{conn_type=\"available\"}) or max(mongodb_ss_connections_available)",
          "legendFormat": "available"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Resident Memory (MB)",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "refId": "A",
          "expr": "max(mongodb_ss_mem_resident_mb) or max(mongodb_ss_mem_resident)",
          "legendFormat": "resident"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "MongoDB Opcounters Rate (ops/s)",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(mongodb_ss_opcounters[5m])) by (type) or sum(rate(mongodb_mongod_op_counters_total[5m])) by (type)",
          "legendFormat": "{{type}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "MongoDB Network Traffic (bytes/s)",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(mongodb_ss_network_bytesIn[5m])) or sum(rate(mongodb_ss_network_bytes_in[5m]))",
          "legendFormat": "bytes in"
        },
        {
          "refId": "B",
          "expr": "sum(rate(mongodb_ss_network_bytesOut[5m])) or sum(rate(mongodb_ss_network_bytes_out[5m]))",
          "legendFormat": "bytes out"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "MongoDB Connections Over Time",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "refId": "A",
          "expr": "max(mongodb_ss_connections) by (conn_type)",
          "legendFormat": "{{conn_type}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "MongoDB Assertions Rate",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(mongodb_ss_asserts[5m])) by (assert_type) or sum(rate(mongodb_asserts_total[5m])) by (assert_type)",
          "legendFormat": "{{assert_type}}"
        }
      ]
    },
    {
      "id": 9,
      "type": "stat",
      "title": "DB Collections",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(mongodb_dbstats_collections)",
          "legendFormat": "collections"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 10,
      "type": "stat",
      "title": "DB Documents",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(mongodb_dbstats_objects)",
          "legendFormat": "documents"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 11,
      "type": "stat",
      "title": "DB Data Size (bytes)",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(mongodb_dbstats_data_size_bytes)",
          "legendFormat": "data size"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Collection Document Counts (Top 10)",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, mongodb_collstats_count)",
          "legendFormat": "{{database}}.{{collection}}"
        }
      ]
    },
    {
      "id": 99,
      "type": "text",
      "title": "Data Source Legend",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 30 },
      "options": {
        "mode": "markdown",
        "content": "**This dashboard uses Prometheus metrics from MongoDB exporter.**\\n\\n- **Prometheus panels**: MongoDB operational/database stats\\n- **Loki logs**: MongoDB logs in Loki dashboards\\n- **Tempo traces**: request traces in Tempo dashboard/Explore\\n- **Langfuse traces/scores/users**: available in Langfuse UI"
      }
    }
  ],
  "templating": { "list": [] },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  }
}
